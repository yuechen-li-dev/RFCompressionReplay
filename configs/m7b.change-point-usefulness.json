                "arCoefficient": 0.92
              }
            }
          }
        ]
      },
      {
        "name": "structure-to-structure-regime-shift",
        "description": "One OFDM-like structured regime transitions into a second OFDM-like regime with a different subcarrier organization and symbol timing. This tests structure-to-structure change detection rather than noise-vs-signal separation.",
